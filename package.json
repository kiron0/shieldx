{
  "name": "shieldx",
  "displayName": "ShieldX - Extension Auditor",
  "description": "Scan installed extensions for security risks, suspicious behavior, and excessive permissions.",
  "version": "0.1.2",
  "publisher": "thk",
  "license": "MIT",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/kiron0/shieldx.git"
  },
  "homepage": "https://shieldx.js.org",
  "bugs": {
    "url": "https://github.com/kiron0/shieldx/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "security",
    "extensions",
    "audit",
    "risk",
    "permissions",
    "firewall"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "shieldx",
          "title": "ShieldX",
          "icon": "assets/icon.svg"
        }
      ]
    },
    "views": {
      "shieldx": [
        {
          "type": "webview",
          "id": "shieldx.dashboard",
          "name": "Security Dashboard",
          "icon": "assets/icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "shieldx.scanExtensions",
        "title": "ShieldX: Scan Installed Extensions"
      },
      {
        "command": "shieldx.openDashboard",
        "title": "ShieldX: Open Security Dashboard"
      },
      {
        "command": "shieldx.exportReport",
        "title": "ShieldX: Export Security Report"
      },
      {
        "command": "shieldx.rescanExtension",
        "title": "ShieldX: Rescan Extension"
      },
      {
        "command": "shieldx.addToAllowlist",
        "title": "ShieldX: Add Extension to Allowlist"
      },
      {
        "command": "shieldx.addToBlocklist",
        "title": "ShieldX: Block Extension"
      },
      {
        "command": "shieldx.showPolicy",
        "title": "ShieldX: Show Current Policy"
      },
      {
        "command": "shieldx.scanVulnerabilities",
        "title": "ShieldX: Scan for OSV Vulnerabilities"
      }
    ],
    "configuration": {
      "title": "ShieldX",
      "properties": {
        "shieldx.autoScanOnStartup": {
          "type": "boolean",
          "default": false,
          "description": "Automatically scan extensions on editor startup"
        },
        "shieldx.warnOnHighRisk": {
          "type": "boolean",
          "default": true,
          "description": "Show warning when high-risk extensions are detected"
        },
        "shieldx.minimumWarningLevel": {
          "type": "string",
          "default": "high",
          "enum": [
            "moderate",
            "high",
            "critical"
          ],
          "description": "Minimum risk level to trigger a warning"
        },
        "shieldx.scanNodeModules": {
          "type": "boolean",
          "default": false,
          "description": "Scan node_modules inside extensions (may be slow)"
        },
        "shieldx.reportFormat": {
          "type": "string",
          "default": "markdown",
          "enum": [
            "markdown",
            "json",
            "html",
            "pdf",
            "csv",
            "sarif"
          ],
          "description": "Default format for exported reports"
        },
        "shieldx.pdfBrowserPath": {
          "type": "string",
          "default": "",
          "description": "Optional absolute path to Chrome, Chromium, Edge, or Brave for exact HTML-to-PDF export"
        },
        "shieldx.enableOsvScan": {
          "type": "boolean",
          "default": true,
          "description": "Enable runtime vulnerability scanning via OSV.dev API (requires network)"
        }
      }
    }
  },
  "scripts": {
    "clean": "bun run ./scripts/clean-build.ts",
    "vscode:prepublish": "npm run compile",
    "compile": "npm run clean && tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build": "npm run compile && vsce package --no-yarn",
    "package": "vsce package --no-yarn",
    "lint": "eslint src --ext ts",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "check-all": "bun run lint && bun run test && bun run build && bun run format"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "@types/vscode": "1.85.0",
    "@vscode/vsce": "^3.9.2",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "jiti": "^2.7.0",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
